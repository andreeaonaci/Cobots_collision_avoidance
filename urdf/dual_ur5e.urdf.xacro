<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="dual_ur5e">

  <!-- ============================== -->
  <!-- World link -->
  <!-- ============================== -->
  <link name="world" />

  <!-- ============================== -->
  <!-- Include UR macros -->
  <!-- ============================== -->

  <!-- Robot 1 -->
  <xacro:include filename="$(find ur_description)/urdf/ur_macro.xacro"/>
  <xacro:ur_robot
    name="ur5e_1"
    tf_prefix="robot1_"
    parent="world"
    joint_limits_parameters_file="$(find ur_description)/config/ur5e/joint_limits.yaml"
    kinematics_parameters_file="$(find ur_description)/config/ur5e/default_kinematics.yaml"
    physical_parameters_file="$(find ur_description)/config/ur5e/physical_parameters.yaml"
    visual_parameters_file="$(find ur_description)/config/ur5e/visual_parameters.yaml"
    robot_ip="0.0.0.0"
    use_fake_hardware="true"
    generate_ros2_control_tag="true"
  >
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </xacro:ur_robot>

  <!-- Robot 2 -->
  <xacro:ur_robot
    name="ur5e_2"
    tf_prefix="robot2_"
    parent="world"
    joint_limits_parameters_file="$(find ur_description)/config/ur5e/joint_limits.yaml"
    kinematics_parameters_file="$(find ur_description)/config/ur5e/default_kinematics.yaml"
    physical_parameters_file="$(find ur_description)/config/ur5e/physical_parameters.yaml"
    visual_parameters_file="$(find ur_description)/config/ur5e/visual_parameters.yaml"
    robot_ip="0.0.0.0"
    use_fake_hardware="true"
    generate_ros2_control_tag="true"
  >
    <!-- Base rotated 180° so Robot 2 faces Robot 1 from spawn — no runtime pan spin needed -->
    <origin xyz="1 0 0" rpy="0 0 3.14159"/>
  </xacro:ur_robot>

  <!-- ============================== -->
  <!-- Inner-side safety sensor frames -->
  <!-- ============================== -->
  <!--
    Both sensors use identical offsets to maintain the same orientation.
    Robot 1 and Robot 2 both face the same direction (Z rotation = 0).
  -->
  <link name="robot1_inner_sensor"/>
  <joint name="robot1_inner_sensor_joint" type="fixed">
    <parent link="robot1_tool0"/>
    <child link="robot1_inner_sensor"/>
    <origin xyz="0 0.10 0" rpy="0 0 0"/>
  </joint>

  <link name="robot2_inner_sensor"/>
  <joint name="robot2_inner_sensor_joint" type="fixed">
    <parent link="robot2_tool0"/>
    <child link="robot2_inner_sensor"/>
    <origin xyz="0 0.10 0" rpy="0 0 0"/>
  </joint>

</robot>